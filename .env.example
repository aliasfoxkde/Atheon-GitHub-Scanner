# Atheon GitHub Scanner - Environment Variables
# Copy this file to .env and configure for your environment

# =============================================================================
# PATHS (for hardcoded path replacement)
# =============================================================================

# Root directory of the scanner project
SCANNER_ROOT=/nas/Temp/repos/Atheon-GitHub-Scanner

# Path to Atheon-Enhanced project (for cross-repo operations)
ATHEON_ENHANCED_PATH=/nas/Temp/repos/Atheon-Enhanced

# Path to Atheon-Benchmark project (for cross-repo operations)
ATHEON_BENCHMARK_PATH=/nas/Temp/repos/Atheon-Benchmark

# Temporary directory for scanner operations
# Uses system temp dir by default (tempfile.gettempdir())
TEMP_DIR=/nas/Temp

# Path for temporary scanner files (package scans, clones, etc.)
ATHEON_SCANNER_PATH=/nas/Temp/atheon-scanner

# =============================================================================
# API TOKENS
# =============================================================================

# GitHub API token for repository scanning (optional, but recommended)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# API token for the real data API endpoints
# API_TOKEN=your_api_token_here

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Comma-separated list of allowed origins for CORS
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# =============================================================================
# WEB APP CONFIGURATION (for web-app/.env)
# =============================================================================

# VITE_API_URL=https://atheon-scanner.pages.dev/api
# VITE_WORKER_API_URL=https://atheon-scanner-api.workers.dev
# VITE_EMBEDDED_DATA_URL=/embedded-data.json
